<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- Tyk coprocess protos — only coprocess_object defines the Dispatcher service -->
    <Protobuf Include="Protos\coprocess_object.proto"               GrpcServices="Server" ProtoRoot="Protos" />
    <Protobuf Include="Protos\coprocess_common.proto"               GrpcServices="None"   ProtoRoot="Protos" />
    <Protobuf Include="Protos\coprocess_mini_request_object.proto"  GrpcServices="None"   ProtoRoot="Protos" />
    <Protobuf Include="Protos\coprocess_response_object.proto"      GrpcServices="None"   ProtoRoot="Protos" />
    <Protobuf Include="Protos\coprocess_return_overrides.proto"     GrpcServices="None"   ProtoRoot="Protos" />
    <Protobuf Include="Protos\coprocess_session_state.proto"        GrpcServices="None"   ProtoRoot="Protos" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" Version="2.64.0" />
  </ItemGroup>

</Project>
